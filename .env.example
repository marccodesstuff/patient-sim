APP_NAME="PatientCommSim"
LOG_LEVEL="INFO"

# --- Patient model ---
PATIENT_PROVIDER="openai"                # openai | anthropic | azure_foundry
PATIENT_MODEL="gpt-4o"
PATIENT_TEMPERATURE=0.7
PATIENT_MAX_TOKENS=512
PATIENT_SEED=42

# --- Judge model ---
JUDGE_PROVIDER="openai"                  # openai | anthropic | azure_foundry
JUDGE_MODEL="gpt-4o"
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_TOKENS=1024

# --- Embeddings ---
EMBEDDING_PROVIDER="openai"              # openai | anthropic | azure_foundry
EMBEDDING_MODEL="text-embedding-3-small"

# --- API keys (do NOT commit real keys) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Azure AI Foundry ---
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=""
AZURE_AI_FOUNDRY_DEPLOYMENT=""
AZURE_AI_FOUNDRY_API_KEY=""

# --- LangSmith (optional) ---
LANGSMITH_API_KEY=""
LANGSMITH_TRACING="false"
LANGSMITH_PROJECT="patient-sim"

# --- Chroma ---
CHROMA_PERSIST_DIR=".chroma"
